  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 201971875372721956, guid: 54e157492bc1847d5aed63927d37b536, type: 3}
      propertyPath: _explanation
      value: Plays sound dead at volume 0,15 and at pitch 1
      objectReference: {fileID: 0}
    - target: {fileID: 716868327495819274, guid: 54e157492bc1847d5aed63927d37b536, type: 3}
      propertyPath: _explanation
      value: "If (IsGrounded(Player)) and when button jump is pressed:\n         
        plays sound jump at volume 0,15 and at pitch 1\n"
      objectReference: {fileID: 0}
    - target: {fileID: 927491107514523717, guid: 54e157492bc1847d5aed63927d37b536, type: 3}
      propertyPath: _explanation
      value: "Reset Level\n----------------\nWhen a collision with a trigger with
        tags [Enemy] starts:\n          Sets the current velocity of Player to a
        speed of 0 units/sec, in the current direction.\n          disables component
        Player (OkapiKit.MovementPlatformer)\n          sets animation parameter
        IsDead of object Player to True\n          plays sound dead at volume 0,15
        and at pitch 1\n then, at 1,5 seconds, \n          switches to scene splash_screen_gameLogo\n"
      objectReference: {fileID: 0}
    - target: {fileID: 1377973852429035859, guid: 54e157492bc1847d5aed63927d37b536, type: 3}
      propertyPath: m_LocalPosition.y
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 4293349580306153410, guid: 54e157492bc1847d5aed63927d37b536, type: 3}
      propertyPath: _explanation
      value: "If (IsGrounded(Player)) and when axis horizontal is held (this can
        only happen every 0,2 seconds):\n          plays sound step at volume 0,15
        and a pitch in the range [0,4,0,7]\n"
      objectReference: {fileID: 0}
    - target: {fileID: 5018350370408917105, guid: 54e157492bc1847d5aed63927d37b536, type: 3}
      propertyPath: _explanation
