--- !u!114 &7794972672755347713
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7701649051835366941}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c3088c41d9f9a9f4ab3a63bd3c155b74, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _showInfo: 1
  _explanation: 'Platformer controller

    ----------------

    Platformer movement;
    horizontal speed is 10 units per second.

    Horizontal movement will be controlled
    by the [Horizontal] axis.

    Ground check is going to use collider GroundCheck,
    the ground layer mask defines what is considered solid ground.

    When there''s
    no solid ground below character, the character will start falling after 0,1s,
    with a gravity scale of 1,5.

    The character''s trajectory can be modified
    mid-air.

    When in the air, the character''s collider will be Player(Player
    (UnityEngine.BoxCollider2D)), and on the ground will be Player(Player (UnityEngine.CapsuleCollider2D)).

    The
    character will jump by holding the [Jump] button.

    The vertical velocity
    will be 10 units/second while jump is pressed, during a maximum of 0,2 seconds.

    Jump
    height will be between 0 to 2 units (from 0,01 to 0,21 seconds to top of trajectory).

    This
    controller also controls some visuals:

    When the player intent is to go left,
    the horizontal scale of this object will be inverted.

    Some values will be
    set on animator Player:

    Horizontal velocity will be set to parameter VelocityX.

    Absolute
    horizontal velocity will be set to parameter AbsVelocityX.

    Vertical velocity
    will be set to parameter VelocityY.

    Absolute vertical velocity will be set
    to parameter AbsVelocityY.

    Grounded state will be set to parameter IsGrounded.

'
  description: Platformer controller
  hasConditions: 0
  conditions: []
  speed: {x: 10, y: 10}
  horizontalInputType: 0
  horizontalAxis: Horizontal
  horizontalButtonPositive: Right
  horizontalButtonNegative: Left
  horizontalKeyPositive: 275
  horizontalKeyNegative: 276
  gravityScale: 1.5
  useTerminalVelocity: 0
  terminalVelocity: 5
  coyoteTime: 0.1
  jumpBehaviour: 2
  maxJumpCount: 1
  jumpBufferingTime: 0
  jumpHoldMaxTime: 0.2
  jumpInputType: 1
  jumpAxis: Vertical
  jumpButton: Jump
  jumpKey: 32
  enableAirControl: 1
  airCollider: {fileID: 3530480185217275068}
  groundCollider: {fileID: 7570332685805579095}
  glideBehaviour: 0
  glideMaxTime: 3.4028235e+38
  maxGlideSpeed: 50
  glideInputType: 2
  glideAxis: Vertical
  glideButton: Jump
  glideKey: 32
  groundCheckCollider: {fileID: 2829931959060159037}
  groundLayerMask:
    serializedVersion: 2
    m_Bits: 2112
  flipBehaviour: 4
  useAnimator: 1
  animator: {fileID: 320779549936540600}
  horizontalVelocityParameter: VelocityX
  absoluteHorizontalVelocityParameter: AbsVelocityX
  verticalVelocityParameter: VelocityY
  absoluteVerticalVelocityParameter: AbsVelocityY
  isGroundedParameter: IsGrounded
  isGlidingParameter: 
